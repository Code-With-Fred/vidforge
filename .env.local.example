# ============================================
# VidForge Environment Configuration
# ============================================
# Copy this file to .env.local and fill in the required values
# DO NOT commit .env.local to version control

# ============================================
# DATABASE
# ============================================
# MongoDB connection string (get from MongoDB Atlas → Connect → Drivers)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vidforge

# ============================================
# EXTERNAL APIs
# ============================================
# Pexels API key for fetching video footage
# Get free key at: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ============================================
# YOUTUBE OAUTH 2.0
# ============================================
# Google OAuth credentials from Google Cloud Console
# Steps:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable YouTube Data API v3
# 4. Create OAuth 2.0 Client ID credentials (Web application)
# 5. Add authorized redirect URIs: http://localhost:3000/api/auth/youtube/callback
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# ============================================
# AI/LLM
# ============================================
# Ollama local model server endpoint
# Install Ollama from https://ollama.com
# Run: ollama pull llama3
# Default runs at http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# APPLICATION
# ============================================
# Environment: development, production, or test
NODE_ENV=development

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# RATE LIMITING
# ============================================
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
